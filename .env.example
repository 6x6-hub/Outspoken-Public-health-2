# Database Configuration
DATABASE_URL=postgresql://outspoken:password@localhost:5432/outspoken_health
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=outspoken
DATABASE_PASSWORD=secure_password_here
DATABASE_NAME=outspoken_health

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# AI/LLM Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# File Upload
MAX_UPLOAD_SIZE=20971520
ALLOWED_FILE_TYPES=jpg,png,pdf,docx
UPLOAD_DIR=./uploads

# Environment
NODE_ENV=development
PORT=3001
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENV=development

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@outspokenpublichealth.zm

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=outspoken-health-files

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Security
CORS_ORIGIN=http://localhost:3000
RATELIMIT_WINDOW_MS=900000
RATELIMIT_MAX_REQUESTS=100
